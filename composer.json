{
	"name": "detain/myadmin-hd-vps-addon",
	"type": "myadmin-plugin",
	"description": "HD Space addon plugin for the VPS module in MyAdmin, enabling purchase and management of additional hard drive space for virtual private servers.",
	"keywords": [
		"hd",
		"vps",
		"addon",
		"myadmin",
		"administration",
		"disk-space"
	],
	"license": "LGPL-2.1-only",
	"authors": [
		{
			"name": "Joe Huss",
			"homepage": "https:\/\/my.interserver.net\/"
		}
	],
	"config": {
		"bin-dir": "vendor\/bin",
		"minimum-stability": "dev"
	},
	"require": {
		"php": ">=5.0.0",
		"ext-soap": "*",
		"symfony/event-dispatcher": "*@stable",
		"detain/myadmin-plugin-installer": "dev-master"
	},
	"require-dev": {
		"phpunit/phpunit": "^9.6"
	},
	"autoload": {
		"psr-4": {
			"Detain\\MyAdminVpsHd\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Detain\\MyAdminVpsHd\\Tests\\": "tests/"
		}
	}
}
